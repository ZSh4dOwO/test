<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AAA — Association des Acupuncteurs{% endblock %}</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav class="nav-container" aria-label="Navigation principale">
        <div class="nav-content">
            <a href="index.php" class="logo" aria-label="AAA - Retour à l'accueil">AAA<span>.</span></a>
            
            <div class="nav-links" role="menubar">
                <a role="menuitem" href="index.php" class="{{ currentPage == 'accueil' ? 'active' : '' }}">Accueil</a>
                <a role="menuitem" href="index.php?page=pathologies" class="{{ currentPage == 'pathologies' ? 'active' : '' }}">Pathologies</a>
                
                {% if isAuthenticated %}
                    <button role="menuitem" class="btn-login" type="submit">Déconnexion</button>
                {% else %}
                    <a role="menuitem" class="btn-login" href="index.php?page=inscription">S'inscrire</a>
                    <button role="menuitem" class="btn-login" onclick="openModal()" aria-haspopup="dialog" aria-controls="login-modal">Connexion</button>
                {% endif %}
            </div>
        </div>
    </nav>
    <a href="#main-content" class="skip-link">Aller au contenu</a>
    <nav class="nav-container" aria-label="Navigation principale">
        <div class="nav-content">
            <div class="logo"><a href="index.php" style="text-decoration:none; color:inherit;">AAA<span>.</span></a></div>
            <div class="nav-links" role="menubar">
                <a role="menuitem" href="index.php" class="{{ currentPage == 'accueil' ? 'active' : '' }}">Accueil</a>
                <a role="menuitem" href="index.php?page=pathologies" class="{{ currentPage == 'pathologies' ? 'active' : '' }}">Pathologies</a>
                {% if isAuthenticated %}
                    <form method="post" style="display:inline;" aria-label="Déconnexion">
                        <input type="hidden" name="action" value="logout">
                        <input type="hidden" name="csrf_token" value="{{ csrfToken }}">
                        <button class="btn-login" type="submit">Déconnexion ({{ userEmail }})</button>
                    </form>
                {% else %}
                    <a class="btn-login" href="index.php?page=inscription">S'inscrire</a>
                    <button class="btn-login" onclick="openModal()" aria-controls="login-modal">Connexion</button>
                {% endif %}
            </div>
        </div>
    </nav>

    {% if flashMessage %}
        <div class="flash-message" role="status" aria-live="polite">{{ flashMessage }}</div>
    {% endif %}

    <main id="main-content">
        {% block body %}{% endblock %}
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 AAA — Association des Acupuncteurs.</p>
        </div>
    </footer>

    <div class="modal-backdrop" id="login-modal" onclick="closeModalBackdrop(event)">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
            <button class="modal-close" onclick="closeModal()" aria-label="Fermer la fenêtre">✕</button>
            <h2 id="modal-title">Connexion</h2>
            <form method="post" action="index.php" aria-label="Formulaire de connexion">
                <input type="hidden" name="action" value="login">
                <input type="hidden" name="csrf_token" value="{{ csrfToken }}">
                <div class="form-group"><label for="login-email">Email</label><input type="email" id="login-email" name="email" required></div>
                <div class="form-group"><label for="login-password">Mot de passe</label><input type="password" id="login-password" name="password" required></div>
                <button type="submit" class="btn-submit">Se connecter</button>
            </form>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
