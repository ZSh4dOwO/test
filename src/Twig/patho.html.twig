{% extends "base.html.twig" %}

{% block body %}
<section class="hero">
    <div class="container">
        <h1 class="l1-title">Détails de la pathologie</h1>
        <p class="hero-intro">{{ patho.patho_desc }} (Type {{ patho.type }}, Méridien {{ patho.mer_nom }})</p>
        <p><a href="index.php?page=pathologies">← Retour à la liste des pathologies</a></p>
    </div>
</section>

<section class="featured-results">
    <div class="container">
        <h2 class="section-label">Symptômes associés</h2>
        {% if patho.symptoms is not empty %}
            <ul class="symptom-list">
                {% for symptom in patho.symptoms %}
                    <li>{{ symptom.symptom_desc }} {% if symptom.aggr %}(aggravation){% endif %}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>Aucun symptôme référencé pour cette pathologie.</p>
        {% endif %}
    </div>
</section>
{% endblock %}
