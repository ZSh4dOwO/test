{% extends "base.html.twig" %}

{% block body %}
<section class="hero">
    <div class="container">
        <h1 class="l1-title" id="title-patho">{{ patho.patho_desc }}</h1>

        <p class="hero-intro">
            <strong>Type :</strong> {{ patho.type }}
            <br>
            <strong>Méridien :</strong> {{ patho.mer_nom }}
        </p>

        <p>
            <a href="index.php?page=accueil" id="retour">← Retour à la liste des pathologies</a>
        </p>
    </div>
</section>

<section class="featured-results">
    <div class="container">
        <h2 class="section-label">Symptômes associés</h2>

        {% if patho.symptoms is not empty %}
            <ul class="symptom-list">
                {% for symptom in patho.symptoms %}
                    <li>
                        {{ symptom.symptom_desc }}
                        {% if symptom.aggr %}
                            <strong>(aggravation)</strong>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="symptom-list">Aucun symptôme référencé pour cette pathologie.</p>
        {% endif %}

        {% if patho.keywords is not empty %}
            <h2 class="section-label" style="margin-top: 2rem;">Mots-clés associés</h2>
            <ul class="symptom-list">
                {% for keyword in patho.keywords %}
                    <li>{{ keyword.name }}</li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</section>
{% endblock %}